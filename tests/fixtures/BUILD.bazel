# Cacheable, ingested-fixture artifact.
#
# `bazelisk build //tests/fixtures:ingested_tng` runs the full
# pipeline (ingest -> commit -> render) against the checked-in TNG-themed
# source JSON and emits two byte-stable outputs:
#
#   * dump.sql -- deterministic CREATE TABLE + sorted INSERT statements,
#                 loadable into a fresh Dolt or any MySQL-compatible engine.
#   * qmd.tar  -- the rendered conversation markdown tree.
#
# Determinism guarantees:
#   * --now is fixed (a TNG-era ISO-8601 stamp).
#   * Source JSON is checked in.
#   * The dumper sorts rows by PK and canonicalizes JSON.
#   * The tar normalizes mtime/uid/gid.
#
# Caveats:
#   * Requires `dolt` on PATH (tagged `requires-dolt` and `no-remote` so
#     it doesn't run on RBE where dolt isn't part of the toolchain).
#   * Uses an ephemeral port chosen at action time, so parallel actions
#     don't collide.
#   * Dolt commit hashes themselves are *not* deterministic and are
#     intentionally not included in either output.

filegroup(
    name = "source_json",
    srcs = glob([
        "anthropic_export/**/*.json",
        "anthropic_api/**/*.json",
        "chatgpt_api/**/*.json",
        "slack_api/**/*.jsonl",
        "slack_api/media/**/*",
        "github_api/**/*.jsonl",
        "gitlab_api/**/*.jsonl",
    ]),
    visibility = ["//visibility:public"],
)

genrule(
    name = "ingested_tng",
    srcs = [":source_json"],
    outs = [
        "ingested/dump.sql",
        "ingested/qmd.tar",
    ],
    tools = [
        "//src/ingest:cli",
        "build_ingested.py",
    ],
    cmd = " ".join([
        "python3 $(execpath build_ingested.py)",
        "$(execpath //src/ingest:cli)",
        # Genrules execute with cwd at the execroot; this is the fixture
        # package's directory inside the sandbox.
        "tests/fixtures",
        "$(RULEDIR)/ingested",
        "'2369-04-15T00:00:00+00:00'",
    ]),
    tags = [
        # Dolt isn't a hermetic toolchain in this repo; rule needs the host
        # binary on PATH and a free TCP port.
        "requires-dolt",
        "no-remote",
        "no-sandbox",
    ],
    visibility = ["//visibility:public"],
)

# Build a QMD (BM25 + embeddings) index over the rendered TNG markdown tree
# and emit it as an overlay tar on top of `:ingested_tng`'s qmd.tar.
#
# Output `qmd-index.tar` mirrors qmd.tar's layout: paths rooted at `qmd/`,
# so extracting both archives into the same directory (e.g. with
# `tar -x --strip-components=1`) yields a complete root data directory —
# markdown tree plus `.frankweiler/qmd/index.sqlite`.
#
# Caveats:
#   * Requires `node` (and network on first run for npx to fetch qmd and its
#     ~2GB embedding models). Tagged accordingly.
#   * SQLite output is NOT byte-stable across runs (timestamps, packing).
#     This rule is correctness-only, not determinism-cacheable.
QMD_VERSION = "2.1.0"

genrule(
    name = "ingested_tng_qmd",
    srcs = ["ingested/qmd.tar"],
    outs = ["ingested/qmd-index.tar"],
    tools = [
        "//frankweiler/backend/qmd_indexer:qmd_indexer_bin",
        "build_qmd_index.py",
    ],
    cmd = " ".join([
        "python3 $(execpath build_qmd_index.py)",
        "$(execpath //frankweiler/backend/qmd_indexer:qmd_indexer_bin)",
        "$(execpath ingested/qmd.tar)",
        "$(execpath ingested/qmd-index.tar)",
        QMD_VERSION,
    ]),
    tags = [
        "requires-network",
        "no-remote",
        "no-sandbox",
    ],
    visibility = ["//visibility:public"],
)
