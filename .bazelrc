common --enable_bzlmod
common --noenable_workspace
test --test_output=errors

# Every bazel action inherits a fixed PATH, not the developer's host
# PATH. Build and test actions resolve `npx`, `cmake`, etc. against
# this PATH, so those tools must be installed somewhere here
# (`/opt/homebrew/bin` covers the brew defaults; `/usr/bin:/bin` covers
# system `make`/`perl`/`cc` etc.). boring-sys2's build script in
# particular shells out to cmake + a C toolchain to build boringssl.
#
# We deliberately do NOT `--action_env=NPX_BIN`. Forwarded host env
# vars contribute to every action's cache key, so any caller-side
# variance (direnv loaded vs not, `which npx` resolving to different
# paths in different shells, agent sessions, CI machines) invalidates
# every cached action — including the expensive boring-sys2 build
# script. Rust call sites still honor `$NPX_BIN` if set at *runtime*
# (handy when running the sync binary directly outside bazel), but
# bazel doesn't propagate it into the action graph.
# Resolver:
#   * NPX_BIN  — frankweiler_qmd_indexer::run_qmd
#                and frankweiler_etl::latchkey::latchkey_command
build --action_env=PATH=/opt/homebrew/bin:/usr/bin:/bin
build --host_action_env=PATH=/opt/homebrew/bin:/usr/bin:/bin
test --test_env=PATH=/opt/homebrew/bin:/usr/bin:/bin

# Mount the host's shared qmd embedding-model cache (`~/.cache/qmd/models`,
# ~2GB of GGUF files) into the sandbox at the same path. Without this,
# the qmd-indexer genrule (`//tests/fixtures:ingested_tng_qmd`) would
# have to re-download the multi-GB model files every action: inside the
# sandbox `$HOME` is remapped to a per-action tmpdir, so an absolute
# path to the host cache is the only way through.
#
# Path matches qmd's own default (`join(homedir(), ".cache", "qmd",
# "models")` in third-party/qmd/src/llm.ts), so a standalone `qmd`
# invocation on the dev host populates the same directory the build
# reads from. //tests/fixtures:qmd_model_cache_path_test enforces
# the match — break it and that test fails.
#
# Safe to mount because the cache is content-keyed (qmd looks up models
# by their HuggingFace repo + filename, never by mtime). Pairs with
# `--action_env=HOME` below so `os.path.expanduser('~')` inside the
# build script resolves to the same host path the mount uses.
#
# `$(HOME)` here is expanded by Bazel at startup time (one of the few
# flags that supports it). If your host is missing the cache dir,
# create it: `mkdir -p ~/.cache/qmd/models`.
build --sandbox_add_mount_pair=$(HOME)/.cache/qmd/models
build --action_env=HOME

# libsqlite3-sys's build script invokes bindgen, which uses
# `clang-sys` to dlopen libclang and parse <sqlite3.h>. Point it at
# Xcode Command Line Tools' bundled libclang.dylib — present on every
# macOS host (incl. GitHub Actions `macos-*` runners) since bazel
# already requires CLT for the C toolchain.
#
# Linux hosts must override on the command line (later flags win):
#   bazel build ... --action_env=LIBCLANG_PATH=$(llvm-config --libdir)
# `release.yml` does this for the linux-amd64 / linux-arm64 matrix
# entries. The devcontainer's user-level ~/.bazelrc carries the same
# override so interactive Linux work doesn't need to remember the flag.
#
# DO NOT set LIBCLANG_PATH via `crate.annotation(... build_script_env)`
# in MODULE.bazel — that wins over `--action_env` and would re-break
# Linux. See the libsqlite3-sys annotation comment.
build --action_env=LIBCLANG_PATH=/Library/Developer/CommandLineTools/usr/lib

# Stamp builds with the git hash via tools/workspace_status.sh. Consumers
# read STABLE_GIT_HASH from bazel-out/stable-status.txt; rust-side surfacing
# lives in frankweiler_core::version::git_hash() (cargo builds use build.rs).
build --workspace_status_command=tools/workspace_status.sh
build --stamp

# Shared content-addressed cache across checkouts. Bazel's action cache lives
# in the per-workspace output base (`_bazel_<user>/<md5-of-workspace-path>/`),
# so two checkouts at different paths (e.g. Dropbox tree vs Sculptor clone)
# don't share hits. The disk cache is keyed by action hash and shared.
build --disk_cache=~/Library/Caches/bazel-disk-cache
test  --disk_cache=~/Library/Caches/bazel-disk-cache

# BuildBuddy remote cache + build event service. Opt-in via
# `--config=buildbuddy` on `build` / `test`; the API key lives in
# `.bazelrc.user` (gitignored) — see the `try-import` at the bottom of
# this file. Without the user file the config is inert; with it,
# subsequent invocations both read from and write to a shared content-
# addressed cache hosted at remote.buildbuddy.io, and post Build Event
# Protocol events to app.buildbuddy.io for inspection.
#
# Why this is huge for our build: actions that anyone (you, CI, the
# devcontainer warmup, a contributor) builds once become cache hits
# for everyone else. boring-sys2's BoringSSL compile, rules_rust's
# crate compiles, and the bzlmod-resolved external repos all flow
# through, so first-build cold cost on a fresh machine drops by ~90%.
#
# `--remote_timeout=600` because the doltlite amalgamation archive is
# fetched through the cache layer and the default 60s is tight for
# multi-MB uploads on residential uplinks.
#
# `--remote_upload_local_results=true` is the default but we name it
# explicitly so it's obvious this is a read+write cache, not a
# read-only mirror. Untrusted CI contexts (PR builds from forks) should
# pass `--remote_upload_local_results=false` to avoid poisoning the
# cache with unverified outputs.
build:buildbuddy --bes_results_url=https://app.buildbuddy.io/invocation/
build:buildbuddy --bes_backend=grpcs://remote.buildbuddy.io
build:buildbuddy --remote_cache=grpcs://remote.buildbuddy.io
build:buildbuddy --remote_timeout=600
build:buildbuddy --remote_upload_local_results=true

# `.bazelrc.user` is per-user (gitignored). Today it carries the
# BuildBuddy `--remote_header=x-buildbuddy-api-key=...` line and an
# `import %workspace%/.bazelrc` line followed by `build --config=buildbuddy`
# (or callers add `--config=buildbuddy` themselves). Template:
#
#     common --remote_header=x-buildbuddy-api-key=<your-api-key>
#     build --config=buildbuddy
#     test  --config=buildbuddy
#
# Get your key at https://app.buildbuddy.io/settings.
try-import %workspace%/.bazelrc.user

# Auto-apply per-OS `build:<os>` configs below based on the build host.
common --enable_platform_specific_config

# Drop dead DT_NEEDED entries from Linux release binaries. libsqlite3-sys's
# build script unconditionally emits `cargo:rustc-link-lib=sqlite3` (no
# `kind=` prefix → defaults to dylib) even when its `bundled` feature is
# on and our `//third-party/doltlite:sqlite3` annotation has already
# statically linked doltlite. Without --as-needed, the linker still
# records `libsqlite3.so` as a DT_NEEDED entry on the final binary, and
# glibc's loader then refuses to launch on hosts without a system
# libsqlite3 — even though no sqlite3_* symbols are actually unresolved
# (verify with `nm -D --undefined-only frankweiler-sync | grep sqlite3`
# → empty). `--as-needed` tells ld to omit DT_NEEDED entries whose
# library contributes no symbols to the final image.
#
# macOS ld64 doesn't accept `-Wl,…` flags in this form and dead-strips
# unused dylibs by default anyway, so this is Linux-only. The flag is
# safe to apply to all Linux Rust links — at worst it's a no-op.
#
# `--host_linkopt` is the exec-config sibling. Bazel's exec config has
# its own flag-application surface, and `--linkopt` alone doesn't
# reach Rust binaries built `[for tool]` (the binaries genrules shell
# out to). Without the host variant, exec-config `frankweiler_sync_bin`
# still has the phantom `libsqlite3.so` DT_NEEDED and refuses to launch
# inside the devcontainer's slim base image during
# `//tests/fixtures:ingested_tng`.
build:linux --linkopt=-Wl,--as-needed
build:linux --host_linkopt=-Wl,--as-needed
