common --enable_bzlmod
common --noenable_workspace
test --test_output=errors

# Every bazel action inherits a fixed PATH, not the developer's host
# PATH. Build and test actions resolve `npx`, `cmake`, etc. against
# this PATH, so those tools must be installed somewhere here
# (`/opt/homebrew/bin` covers the brew defaults; `/usr/bin:/bin` covers
# system `make`/`perl`/`cc` etc.). boring-sys2's build script in
# particular shells out to cmake + a C toolchain to build boringssl.
#
# We deliberately do NOT `--action_env=NPX_BIN`. Forwarded host env
# vars contribute to every action's cache key, so any caller-side
# variance (direnv loaded vs not, `which npx` resolving to different
# paths in different shells, agent sessions, CI machines) invalidates
# every cached action — including the expensive boring-sys2 build
# script. Rust call sites still honor `$NPX_BIN` if set at *runtime*
# (handy when running the sync binary directly outside bazel), but
# bazel doesn't propagate it into the action graph.
# Resolver:
#   * NPX_BIN  — frankweiler_qmd_indexer::run_qmd
#                and frankweiler_etl::latchkey::latchkey_command
build --action_env=PATH=/opt/homebrew/bin:/usr/bin:/bin
build --host_action_env=PATH=/opt/homebrew/bin:/usr/bin:/bin
test --test_env=PATH=/opt/homebrew/bin:/usr/bin:/bin

# Mount the host's shared qmd embedding-model cache (`~/.cache/qmd/models`,
# ~2GB of GGUF files) into the sandbox at the same path. Without this,
# the qmd-indexer genrule (`//tests/fixtures:ingested_tng_qmd`) would
# have to re-download the multi-GB model files every action: inside the
# sandbox `$HOME` is remapped to a per-action tmpdir, so an absolute
# path to the host cache is the only way through.
#
# Path matches qmd's own default (`join(homedir(), ".cache", "qmd",
# "models")` in third-party/qmd/src/llm.ts), so a standalone `qmd`
# invocation on the dev host populates the same directory the build
# reads from. //tests/fixtures:qmd_model_cache_path_test enforces
# the match — break it and that test fails.
#
# Safe to mount because the cache is content-keyed (qmd looks up models
# by their HuggingFace repo + filename, never by mtime). Pairs with
# `--action_env=HOME` below so `os.path.expanduser('~')` inside the
# build script resolves to the same host path the mount uses.
#
# `$(HOME)` here is expanded by Bazel at startup time (one of the few
# flags that supports it). If your host is missing the cache dir,
# create it: `mkdir -p ~/.cache/qmd/models`.
build --sandbox_add_mount_pair=$(HOME)/.cache/qmd/models
build --action_env=HOME

# libsqlite3-sys's build script invokes bindgen, which uses
# `clang-sys` to dlopen libclang and parse <sqlite3.h>. Point it at
# Xcode Command Line Tools' bundled libclang.dylib — present on every
# macOS host (incl. GitHub Actions `macos-*` runners) since bazel
# already requires CLT for the C toolchain.
#
# `--host_action_env` mirrors `--action_env` so the *exec*-config copy
# of every bindgen build script finds libclang too. boring-sys2 (and
# other `wreq`/BoringSSL users) gets built `[for tool]` whenever an
# exec-config build tool in the `//...` graph depends on the HTTP
# stack; without the host variant that exec-config bindgen panics with
# "Unable to find libclang" the moment the action isn't a cache hit —
# which is exactly what reddened `bazel test //...` in CI on a cold
# BuildBuddy cache. `--action_env` alone only covers target-config
# actions, so the failure hid behind the remote cache until a miss.
#
# Linux hosts must override both on the command line (later flags win):
#   bazel build ... --action_env=LIBCLANG_PATH=$(llvm-config --libdir) \
#                   --host_action_env=LIBCLANG_PATH=$(llvm-config --libdir)
# `release.yml` does this for the linux-amd64 / linux-arm64 matrix
# entries. The devcontainer's user-level ~/.bazelrc carries the same
# override so interactive Linux work doesn't need to remember the flag.
#
# DO NOT set LIBCLANG_PATH via `crate.annotation(... build_script_env)`
# in MODULE.bazel — that wins over `--action_env` and would re-break
# Linux. See the libsqlite3-sys annotation comment.
build --action_env=LIBCLANG_PATH=/Library/Developer/CommandLineTools/usr/lib
build --host_action_env=LIBCLANG_PATH=/Library/Developer/CommandLineTools/usr/lib

# Workspace status — tools/workspace_status.sh emits STABLE_GIT_HASH +
# STABLE_GIT_DESCRIBE. Always run so any `--config=release` invocation
# has fresh values; the script itself is sub-second.
build --workspace_status_command=tools/workspace_status.sh

# Stamping (`--stamp`) is OFF by default and ON only for release
# builds (`--config=release`).
#
# When `--stamp` is on, every action that consumes workspace status —
# in this repo, just `frankweiler_sync_bin`'s rustc_env_files
# substitution of {STABLE_GIT_HASH} / {STABLE_GIT_DESCRIBE} — picks
# up the new git SHA on every commit, which invalidates its action
# cache key. Result: every commit forced a rebuild of the sync
# binary even when no rust changed.
#
# We don't care about a stamped binary for day-to-day work — the
# `frankweiler-sync --version` output reads "unknown" off the
# `option_env!` fallback in version.rs, which is fine for dev. When
# building a release artifact, pass `--config=release` to opt back in.
build:release --stamp

# Shared content-addressed cache across checkouts. Bazel's action cache lives
# in the per-workspace output base (`_bazel_<user>/<md5-of-workspace-path>/`),
# so two checkouts at different paths (e.g. Dropbox tree vs Sculptor clone)
# don't share hits. The disk cache is keyed by action hash and shared.
build --disk_cache=~/Library/Caches/bazel-disk-cache
test  --disk_cache=~/Library/Caches/bazel-disk-cache

# BuildBuddy remote cache + build event service. Opt-in via
# `--config=buildbuddy` on `build` / `test`; the API key lives in
# `.bazelrc.user` (gitignored) — see the `try-import` at the bottom of
# this file. Without the user file the config is inert; with it,
# subsequent invocations both read from and write to a shared content-
# addressed cache hosted at imbue.buildbuddy.io (our org-scoped
# endpoint), and post Build Event Protocol events to the same host for
# inspection.
#
# Why this is huge for our build: actions that anyone (you, CI, the
# devcontainer warmup, a contributor) builds once become cache hits
# for everyone else. boring-sys2's BoringSSL compile, rules_rust's
# crate compiles, and the bzlmod-resolved external repos all flow
# through, so first-build cold cost on a fresh machine drops by ~90%.
#
# `--remote_timeout=600` because the doltlite amalgamation archive is
# fetched through the cache layer and the default 60s is tight for
# multi-MB uploads on residential uplinks.
#
# `--remote_upload_local_results=true` is the default but we name it
# explicitly so it's obvious this is a read+write cache, not a
# read-only mirror. Untrusted CI contexts (PR builds from forks) should
# pass `--remote_upload_local_results=false` to avoid poisoning the
# cache with unverified outputs.
build:buildbuddy --bes_results_url=https://imbue.buildbuddy.io/invocation/
build:buildbuddy --bes_backend=grpcs://imbue.buildbuddy.io
build:buildbuddy --remote_cache=grpcs://imbue.buildbuddy.io
build:buildbuddy --remote_timeout=600
build:buildbuddy --remote_upload_local_results=true

# Fully-static musl release builds. Selects the musl platform for the
# TARGET configuration only: build scripts, proc macros, and genrule
# tools keep running under the host (gnu/darwin) toolchains, so these
# configs are safe to combine with any build. Used by release.yml's
# `*-unknown-linux-musl` matrix legs:
#
#     bazelisk build //frankweiler/backend:dist -c opt --config=musl-x86_64
#
# MODULE.bazel registers the same musl target toolchains for Apple
# Silicon hosts, so much of the release path can be debugged locally
# (e.g. `frankweiler_http_bin` cross-builds to a fully-static ELF from
# a mac). The known exception: anything that pulls boring-sys2 (wreq —
# so `latchkey_curl_shim` and `frankweiler_sync_bin`) only musl-builds
# with a Linux exec platform (the CI runners, the devcontainer),
# because boring-sys2's build script runs bindgen against the musl
# target triple, which needs linux libc headers on the include path;
# a linux host supplies them via /usr/include, a mac has none for a
# linux triple and bindgen dies on `stddef.h`. The `bazel build ...
# (musl static)` step in test.yml gates the full musl dist on every
# PR, so darwin's partial coverage is fine.
#
# The resulting binaries are statically linked against musl libc (no
# DT_NEEDED entries at all — verify with `file`, which should say
# "statically linked" / "static-pie linked"), so they run on any Linux
# of the right arch regardless of libc.
# FIXME(toolchains_musl-bazel9): the autoload line below is a
# TEMPORARY bridge — DROP it once toolchains_musl publishes a release
# containing bazel-contrib/musl-toolchain#67 (merged 2026-05-03,
# unreleased as of 0.1.27) and we bump to it. The v0.1.27 toolchain
# tarballs still use three natives that Bazel 9 removed from the
# builtins (`CcToolchainConfigInfo`, `cc_toolchain`,
# `cc_common.create_cc_toolchain_config_info`); `+symbol` re-injects
# just those three from rules_cc at loading time. Scoped to the musl
# configs (via the shared `musl` base config) so every non-musl build
# keeps stock Bazel 9 symbol resolution.
build:musl --incompatible_autoload_externally=+CcToolchainConfigInfo,+cc_toolchain,+cc_common
build:musl-x86_64 --config=musl
build:musl-x86_64 --platforms=//platforms:linux_x86_64_musl
build:musl-aarch64 --config=musl
build:musl-aarch64 --platforms=//platforms:linux_aarch64_musl

# `.bazelrc.user` is per-user (gitignored). Today it carries the
# BuildBuddy `--remote_header=x-buildbuddy-api-key=...` line and an
# `import %workspace%/.bazelrc` line followed by `build --config=buildbuddy`
# (or callers add `--config=buildbuddy` themselves). Template:
#
#     common --remote_header=x-buildbuddy-api-key=<your-api-key>
#     build --config=buildbuddy
#     test  --config=buildbuddy
#
# Get your key at https://imbue.buildbuddy.io/settings.
try-import %workspace%/.bazelrc.user

# Auto-apply per-OS `build:<os>` configs below based on the build host.
common --enable_platform_specific_config

# Drop dead DT_NEEDED entries from Linux release binaries. libsqlite3-sys's
# build script unconditionally emits `cargo:rustc-link-lib=sqlite3` (no
# `kind=` prefix → defaults to dylib) even when its `bundled` feature is
# on and our `//third-party/doltlite:sqlite3` annotation has already
# statically linked doltlite. Without --as-needed, the linker still
# records `libsqlite3.so` as a DT_NEEDED entry on the final binary, and
# glibc's loader then refuses to launch on hosts without a system
# libsqlite3 — even though no sqlite3_* symbols are actually unresolved
# (verify with `nm -D --undefined-only frankweiler-sync | grep sqlite3`
# → empty). `--as-needed` tells ld to omit DT_NEEDED entries whose
# library contributes no symbols to the final image.
#
# macOS ld64 doesn't accept `-Wl,…` flags in this form and dead-strips
# unused dylibs by default anyway, so this is Linux-only. The flag is
# safe to apply to all Linux Rust links — at worst it's a no-op.
#
# `--host_linkopt` is the exec-config sibling. Bazel's exec config has
# its own flag-application surface, and `--linkopt` alone doesn't
# reach Rust binaries built `[for tool]` (the binaries genrules shell
# out to). Without the host variant, exec-config `frankweiler_sync_bin`
# still has the phantom `libsqlite3.so` DT_NEEDED and refuses to launch
# inside the devcontainer's slim base image during
# `//tests/fixtures:ingested_tng`.
build:linux --linkopt=-Wl,--as-needed
build:linux --host_linkopt=-Wl,--as-needed

# rustfmt-check is **always on** for every bazel build/test. This
# forbids `bazelisk test //...` from running against unformatted code,
# which would otherwise mean: developer runs tests → fix-up `cargo fmt`
# at commit time → bazel action cache invalidates → 30-40s of recompile
# on every commit. With the aspect always active, `bazelisk test //...`
# fails fast if any file is misformatted; dev runs `cargo fmt`; reruns
# tests; the test compiles the final formatted bytes; commit hits cache.
#
# rustfmt check is a fast per-crate action; the cold-cache cost is
# small and goes entirely to BuildBuddy's remote cache on shared work.
build --aspects=@rules_rust//rust:defs.bzl%rustfmt_aspect
build --output_groups=+rustfmt_checks

# `--config=clippy` — run rules_rust's clippy aspect across the build
# graph. Replaces `cargo clippy --all-targets --all-features --
# -D warnings` in scripts/pre-commit because the cargo invocation has
# its own incremental cache (separate from bazel's) and went cold
# after every bazel build, eating 1–2 minutes per commit. The aspect
# shares bazel's action cache + BuildBuddy remote cache, so a warm
# `bazelisk build --config=clippy //...` is sub-second.
# Clippy aspect activation lives on `build:clippy` — only here do
# we ask bazel to actually run the lint aspect and surface its
# outputs. (Unlike rustfmt above, clippy is opt-in because warnings
# can be noisier and we wanted the gate to be commit-time, not
# every-test-time.)
build:clippy --aspects=@rules_rust//rust:defs.bzl%rust_clippy_aspect
build:clippy --output_groups=+clippy_checks

# Clippy *configuration* (the .toml file + flags) is set on plain
# `build` so it has the same constant value on every command. These
# are Starlark build settings that ride with the analysis cache;
# leaving them only under `build:clippy` made every alternation
# between `bazel build --config=clippy //...` (pre-commit hook)
# and a bare `bazel test //...` flip the values and discard the
# analysis cache.
#
# Setting them globally is a no-op for non-clippy actions: without
# the aspect activation above, the clippy aspect never runs, so no
# action reads these settings. The compile actions for rust_library
# / rust_binary don't depend on them.
#
# Auto-discover via the workspace clippy.toml. clippy is picky about
# the filename (must be `clippy.toml` or `.clippy.toml`); ours lives
# at frankweiler/backend/clippy.toml and is exported via that
# package's BUILD.bazel.
build --@rules_rust//rust/settings:clippy.toml=//frankweiler/backend:clippy.toml
# Warnings-as-errors, matching `-D warnings` from the old cargo
# invocation. `disallowed_macros` was the lint clippy.toml's
# `disallowed-macros` table relied on being warned (then promoted to
# error by `-D warnings`) — same here.
build --@rules_rust//:clippy_flags=-Dwarnings,-Wclippy::disallowed_macros
