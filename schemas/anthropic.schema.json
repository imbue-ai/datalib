{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://imbue.com/schemas/anthropic.schema.json",
  "title": "AnthropicMirrorSchema",
  "description": "Source-of-truth row shapes for the anthropic_* tables produced by claude-mirror and consumed by frankweiler.",
  "type": "object",
  "definitions": {
    "Account": {
      "type": "object",
      "required": ["account_uuid", "first_seen_at", "last_seen_at"],
      "properties": {
        "account_uuid": {"type": "string"},
        "full_name": {"type": ["string", "null"]},
        "email_address": {"type": ["string", "null"]},
        "first_seen_at": {"type": "string", "format": "date-time"},
        "last_seen_at": {"type": "string", "format": "date-time"}
      }
    },
    "Project": {
      "type": "object",
      "required": ["project_uuid", "first_seen_at", "last_seen_at"],
      "properties": {
        "project_uuid": {"type": "string"},
        "account_uuid": {"type": ["string", "null"]},
        "name": {"type": ["string", "null"]},
        "description": {"type": ["string", "null"]},
        "first_seen_at": {"type": "string", "format": "date-time"},
        "last_seen_at": {"type": "string", "format": "date-time"}
      }
    },
    "Conversation": {
      "type": "object",
      "required": ["conversation_uuid", "account_uuid", "created_at", "updated_at", "first_seen_at", "last_seen_at"],
      "properties": {
        "conversation_uuid": {"type": "string"},
        "account_uuid": {"type": "string"},
        "project_uuid": {"type": ["string", "null"]},
        "name": {"type": ["string", "null"]},
        "summary": {"type": ["string", "null"]},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "first_seen_at": {"type": "string", "format": "date-time"},
        "last_seen_at": {"type": "string", "format": "date-time"}
      }
    },
    "Message": {
      "type": "object",
      "required": ["message_uuid", "conversation_uuid", "sender", "created_at", "updated_at", "first_seen_at", "last_seen_at"],
      "properties": {
        "message_uuid": {"type": "string"},
        "conversation_uuid": {"type": "string"},
        "parent_message_uuid": {"type": ["string", "null"]},
        "sender": {"type": "string", "enum": ["human", "assistant", "system", "tool"]},
        "text": {"type": ["string", "null"]},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "first_seen_at": {"type": "string", "format": "date-time"},
        "last_seen_at": {"type": "string", "format": "date-time"}
      }
    },
    "ContentBlock": {
      "type": "object",
      "required": ["message_uuid", "ordinal", "type"],
      "properties": {
        "message_uuid": {"type": "string"},
        "ordinal": {"type": "integer", "minimum": 0},
        "type": {"type": "string"},
        "text": {"type": ["string", "null"]},
        "metadata_json": {"type": ["string", "null"]}
      }
    },
    "Attachment": {
      "type": "object",
      "required": ["attachment_uuid", "message_uuid"],
      "properties": {
        "attachment_uuid": {"type": "string"},
        "message_uuid": {"type": "string"},
        "file_name": {"type": ["string", "null"]},
        "file_type": {"type": ["string", "null"]},
        "file_size": {"type": ["integer", "null"]},
        "extracted_content": {"type": ["string", "null"]}
      }
    }
  },
  "tables": {
    "anthropic_accounts": "#/definitions/Account",
    "anthropic_projects": "#/definitions/Project",
    "anthropic_conversations": "#/definitions/Conversation",
    "anthropic_messages": "#/definitions/Message",
    "anthropic_content_blocks": "#/definitions/ContentBlock",
    "anthropic_attachments": "#/definitions/Attachment"
  }
}
