load("@rules_python//python:defs.bzl", "py_binary")

exports_files([
    "anthropic.schema.json",
    "grid_rows.schema.json",
    "codegen.py",
])

py_binary(
    name = "codegen",
    srcs = ["codegen.py"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "anthropic_rs",
    srcs = ["anthropic.schema.json"],
    outs = ["anthropic.rs"],
    cmd = "$(execpath :codegen) $(execpath anthropic.schema.json) --rust $@",
    tools = [":codegen"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "anthropic_py",
    srcs = ["anthropic.schema.json"],
    outs = ["anthropic.py"],
    cmd = "$(execpath :codegen) $(execpath anthropic.schema.json) --python $@",
    tools = [":codegen"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "anthropic_ts",
    srcs = ["anthropic.schema.json"],
    outs = ["anthropic.ts"],
    cmd = "$(execpath :codegen) $(execpath anthropic.schema.json) --typescript $@",
    tools = [":codegen"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "anthropic_all",
    srcs = [
        ":anthropic_py",
        ":anthropic_rs",
        ":anthropic_ts",
    ],
    visibility = ["//visibility:public"],
)

genrule(
    name = "grid_rows_rs",
    srcs = ["grid_rows.schema.json"],
    outs = ["grid_rows.rs"],
    cmd = "$(execpath :codegen) $(execpath grid_rows.schema.json) --rust $@",
    tools = [":codegen"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "grid_rows_py",
    srcs = ["grid_rows.schema.json"],
    outs = ["grid_rows.py"],
    cmd = "$(execpath :codegen) $(execpath grid_rows.schema.json) --python $@",
    tools = [":codegen"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "grid_rows_ts",
    srcs = ["grid_rows.schema.json"],
    outs = ["grid_rows.ts"],
    cmd = "$(execpath :codegen) $(execpath grid_rows.schema.json) --typescript $@",
    tools = [":codegen"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "grid_rows_all",
    srcs = [
        ":grid_rows_py",
        ":grid_rows_rs",
        ":grid_rows_ts",
    ],
    visibility = ["//visibility:public"],
)
