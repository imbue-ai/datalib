"""Repo-root Bzlmod module for the personal-data mirror.

Bazel owns:
  - `claude-mirror/`  Python ingestion (deps from uv.lock via rules_python)
  - (later) `schemas/` cross-language types
  - (later) `frankweiler/backend/*` Rust crates
  - (later) `frankweiler/ui/` Vue + Vitest

Bazel does NOT own:
  - The Tauri bundler (driven via cargo/pnpm directly)
  - OpenHost docker builds
  - The local `uv` venv used for editor/inner-loop work
"""

module(
    name = "personal_mirror",
    version = "0.0.1",
)

# Rules Python — pinned to a recent stable. uv.lock ingestion via pip.parse.
bazel_dep(name = "rules_python", version = "1.7.0")

PYTHON_VERSION = "3.13"

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = PYTHON_VERSION,
)

pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "claude_mirror_pip",
    python_version = PYTHON_VERSION,
    requirements_lock = "//claude-mirror:requirements.txt",
)
use_repo(pip, "claude_mirror_pip")
