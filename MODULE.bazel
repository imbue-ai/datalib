"""Repo-root Bzlmod module for the personal-data mirror.

Version policy: 7-day burn-in. We avoid versions released in the last 7
days because hot releases are where regressions hide. When bumping a
bazel_dep or a toolchain, check the upstream release date and prefer
the newest version that is at least 7 days old. Today's working
reference (2026-05-07): rules_python 2.0.0, rules_rust 0.70.0,
Rust 1.95.0, Bazel 9.1.0.

Bazel owns:
  - `claude-mirror/`  Python ingestion (deps from uv.lock via rules_python)
  - (later) `schemas/` cross-language types
  - (later) `frankweiler/backend/*` Rust crates
  - (later) `frankweiler/ui/` Vue + Vitest

Bazel does NOT own:
  - The Tauri bundler (driven via cargo/pnpm directly)
  - OpenHost docker builds
  - The local `uv` venv used for editor/inner-loop work
"""

module(
    name = "personal_mirror",
    version = "0.0.1",
)

# Rules Shell — provides sh_binary etc. (split out of bazel core in Bazel 8/9).
bazel_dep(name = "rules_shell", version = "0.6.1")

# Rules Python — pinned to a recent stable. uv.lock ingestion via pip.parse.
bazel_dep(name = "rules_python", version = "2.0.0")

PYTHON_VERSION = "3.13"

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = PYTHON_VERSION,
)

pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "claude_mirror_pip",
    python_version = PYTHON_VERSION,
    requirements_lock = "//claude-mirror:requirements.txt",
)
use_repo(pip, "claude_mirror_pip")

# Rust — rules_rust + crate_universe ingesting frankweiler/backend Cargo workspace.
bazel_dep(name = "rules_rust", version = "0.70.0")

rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(
    edition = "2021",
    versions = ["1.95.0"],
)
use_repo(rust, "rust_toolchains")

register_toolchains("@rust_toolchains//:all")

crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
crate.from_cargo(
    name = "frankweiler_crates",
    cargo_lockfile = "//frankweiler/backend:Cargo.lock",
    manifests = [
        "//frankweiler/backend:Cargo.toml",
        "//frankweiler/backend/schema:Cargo.toml",
        "//frankweiler/backend/core:Cargo.toml",
        "//frankweiler/backend/http:Cargo.toml",
        "//frankweiler/backend/tauri-backend:Cargo.toml",
    ],
)
use_repo(crate, "frankweiler_crates")
