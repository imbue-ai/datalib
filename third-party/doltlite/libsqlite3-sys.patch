 use std::env;
-use std::path::Path;
+use std::path::{Path, PathBuf};
+
+/// Absolutize `SQLITE3_INCLUDE_DIR` / `SQLITE3_LIB_DIR` when they're
+/// passed as workspace-relative `bazel-out/...` paths.
+///
+/// rules_rust's `build_script_env` supports `$(BINDIR)` substitution,
+/// which emits a workspace-relative path. But the build script runs
+/// from a deep subdirectory of execroot, so bindgen's relative-path
+/// resolution against the build script's CWD fails. This shim derives
+/// the absolute execroot from `CARGO_MANIFEST_DIR` (bazel always sets
+/// that to an absolute path) and rewrites the env vars before any
+/// downstream code reads them. Outside bazel (regular cargo build),
+/// `CARGO_MANIFEST_DIR` doesn't contain `bazel-out/` and this is a
+/// no-op.
+fn absolutize_bazel_env(name: &str) {
+    let Ok(val) = env::var(name) else { return };
+    if val.is_empty() || Path::new(&val).is_absolute() {
+        return;
+    }
+    let Ok(manifest) = env::var("CARGO_MANIFEST_DIR") else { return };
+    let Some(idx) = manifest.find("/bazel-out/") else { return };
+    let execroot = &manifest[..idx];
+    let abs = PathBuf::from(execroot).join(&val);
+    if abs.exists() {
+        env::set_var(name, abs.as_os_str());
+    }
+}

