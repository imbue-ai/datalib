load("@rules_cc//cc:defs.bzl", "cc_library")

# Public patches consumed by crate_universe annotations in MODULE.bazel.
exports_files(
    glob(["*.patch"]),
    visibility = ["//visibility:public"],
)

# `sqlite3` — a from-source doltlite build, compiled once by Bazel and
# statically linked into every Rust binary that pulls in sqlx-sqlite
# (transitively via `libsqlite3-sys`).
#
# Single-TU build from the doltlite amalgamation. As of v0.11.4 the
# amalgamation bundles the SQLite core, the prolly storage engine, the
# `dolt_commit`/`dolt_log`/… version-control SQL surface, blake3 with
# runtime SIMD dispatch, and the SQLite extensions (FTS3/4/5, RTree,
# session, RBU, stmt vtable) all into one `doltlite.c`. We rename it
# to `sqlite3.{c,h}` so libsqlite3-sys's build script — which looks
# for `sqlite3.h` on $SQLITE3_INCLUDE_DIR and a `libsqlite3.a` on
# $SQLITE3_LIB_DIR — finds what it expects.
#
# Cache shape:
#   * The amalgamation lives in `@doltlite_amalgamation//` — a bzlmod
#     http_archive pinned by sha256 in MODULE.bazel. Bazel fetches the
#     zip exactly once per pin, ever, across every build/host.
#   * The rename genrule is keyed on the source digests; trivial cost.
#   * The cc_library action is keyed on the (single) source digest
#     plus the C toolchain hermetic action key, so it rebuilds only
#     when one of those moves. Touching Rust code never invalidates it.
#   * Downstream Rust crates depend on `:sqlite3` via a crate_universe
#     annotation on `libsqlite3-sys` (see MODULE.bazel) so a single
#     .a flows into every binary.

# Surface `doltlite.{c,h}` at the canonical `sqlite3.{c,h}` names.
genrule(
    name = "rename_amalgamation",
    srcs = [
        "@doltlite_amalgamation//:doltlite.c",
        "@doltlite_amalgamation//:doltlite.h",
    ],
    outs = [
        "sqlite3.c",
        "sqlite3.h",
    ],
    cmd = """
        cp $(location @doltlite_amalgamation//:doltlite.c) $(location sqlite3.c)
        cp $(location @doltlite_amalgamation//:doltlite.h) $(location sqlite3.h)
    """,
    visibility = ["//visibility:public"],
)

# cc_library named `sqlite3` so Bazel emits `libsqlite3.a` (Bazel's
# convention is to prepend `lib` to the rule name). This matches what
# `libsqlite3-sys`'s build script expects to find when it emits
# `cargo:rustc-link-lib=sqlite3` against $SQLITE3_LIB_DIR.
cc_library(
    name = "sqlite3",
    srcs = ["sqlite3.c"],
    hdrs = ["sqlite3.h"],
    includes = ["."],
    copts = [
        # The amalgamation self-defines DOLTLITE_PROLLY=1 and SQLITE_CORE
        # at the top of doltlite.c, but we set them explicitly so the
        # intent is visible at this layer too.
        "-DDOLTLITE_PROLLY=1",
        "-DDOLTLITE_VERSION=\\\"0.11.4\\\"",
        "-DSQLITE_CORE",
        # SQLite vtable extensions doltlite enables by default; we
        # repeat them here so the amalgamation's extension init code
        # (statically compiled in) matches what sqlx-sqlite expects.
        "-DSQLITE_ENABLE_BYTECODE_VTAB",
        "-DSQLITE_ENABLE_DBPAGE_VTAB",
        "-DSQLITE_ENABLE_DBSTAT_VTAB",
        "-DSQLITE_ENABLE_FTS3",
        "-DSQLITE_ENABLE_FTS4",
        "-DSQLITE_ENABLE_FTS5",
        "-DSQLITE_ENABLE_RTREE",
        "-DSQLITE_ENABLE_STMTVTAB",
        "-DSQLITE_ENABLE_JSON1",
        "-DSQLITE_ENABLE_UNLOCK_NOTIFY",
        # sqlx-sqlite calls sqlite3_column_{database,origin,table}_name
        # for nullability inference. They're only defined when SQLite
        # is built with this flag.
        "-DSQLITE_ENABLE_COLUMN_METADATA",
        "-DSQLITE_THREADSAFE=1",
        "-DSQLITE_DEFAULT_FOREIGN_KEYS=1",
        # Silence the noisier doltlite/SQLite build warnings — they
        # live in upstream-shaped code we don't own.
        "-Wno-unused-but-set-variable",
        "-Wno-unused-function",
        "-Wno-unused-parameter",
        "-Wno-unused-variable",
        "-Wno-unused-but-set-parameter",
        "-Wno-implicit-fallthrough",
        "-Wno-sign-compare",
        "-Wno-deprecated-non-prototype",
    ],
    linkopts = select({
        # POSIX threads for SQLITE_THREADSAFE=1; dl is needed if anyone
        # ever calls sqlite3_load_extension at runtime (we don't, but
        # the symbol references dlopen so the linker complains
        # otherwise on Linux).
        "@platforms//os:linux": [
            "-lpthread",
            "-ldl",
            "-lm",
        ],
        "@platforms//os:macos": [],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
