load("@rules_cc//cc:defs.bzl", "cc_library")

# Public patches consumed by crate_universe annotations in MODULE.bazel.
exports_files(
    glob(["*.patch"]),
    visibility = ["//visibility:public"],
)

# `sqlite3` — a from-source doltlite build, compiled once by Bazel
# and statically linked into every Rust binary that pulls in
# sqlx-sqlite (transitively via `libsqlite3-sys`).
#
# Why we compile every individual source file rather than using
# `sqlite3.c` (the amalgamation): per upstream's `main.mk`, a
# DOLTLITE_PROLLY=1 build takes the non-amalgamation code path. The
# amalgamation declares the prolly hooks as `SQLITE_PRIVATE` (=
# `static`), so their external-linkage definitions in `prolly_btree.c`
# can't satisfy them — the only way to link a working prolly build is
# to compile the engine + dolt-SQL files into the same archive as the
# core sources. We mirror upstream's PROLLY-mode link set: every
# `src/*.c` (minus the five files the prolly engine replaces — btree,
# pager, wal, btmutex, backup), every `doltlite_*.c` + `prolly_*.c` +
# `chunk_*.c` + `*_orig.c` file, every blake3 source with
# platform-appropriate SIMD, the listed SQLite extensions, and the
# Lemon-generated parser tables.
#
# Cache shape:
#   * The doltlite source lives in `@doltlite_amalgamation//` — a
#     bzlmod http_archive pinned by sha256 in MODULE.bazel. Bazel
#     fetches the autoconf tarball exactly once per pin, ever, across
#     every build/host.
#   * This cc_library action is keyed on every source file digest
#     plus the C toolchain hermetic action key, so it rebuilds only
#     when one of those moves. Touching Rust code never invalidates it.
#   * Downstream Rust crates depend on `:sqlite3` via a crate_universe
#     annotation on `libsqlite3-sys` (see MODULE.bazel) so a single
#     .a flows into every binary.

# Surface the public header at the canonical name `sqlite3.h` in our
# package so consumers can do `#include <sqlite3.h>` and find it via
# the `:sqlite3.h` label that MODULE.bazel's `build_script_data`
# references.
genrule(
    name = "copy_sqlite_header",
    srcs = [
        "@doltlite_amalgamation//:sqlite3.h",
        "@doltlite_amalgamation//:sqlite3ext.h",
    ],
    outs = [
        "sqlite3.h",
        "sqlite3ext.h",
    ],
    cmd = """
        cp $(location @doltlite_amalgamation//:sqlite3.h) $(location sqlite3.h)
        cp $(location @doltlite_amalgamation//:sqlite3ext.h) $(location sqlite3ext.h)
    """,
    visibility = ["//visibility:public"],
)

# cc_library named `sqlite3` so Bazel emits `libsqlite3.a` (Bazel's
# convention is to prepend `lib` to the rule name). This matches what
# `libsqlite3-sys`'s build script expects to find when it emits
# `cargo:rustc-link-lib=sqlite3` against `SQLITE3_LIB_DIR`.
cc_library(
    name = "sqlite3",
    srcs = [
        "@doltlite_amalgamation//:sqlite_core_src",
        "@doltlite_amalgamation//:doltlite_engine_src",
        "@doltlite_amalgamation//:sqlite_extension_src",
        "@doltlite_amalgamation//:sqlite_generated_src",
        "@doltlite_amalgamation//:blake3_portable_src",
    ] + select({
        "@platforms//cpu:x86_64": [
            "@doltlite_amalgamation//:blake3_x86_simd_src",
        ],
        "@platforms//cpu:aarch64": [
            "@doltlite_amalgamation//:blake3_arm_simd_src",
        ],
        "//conditions:default": [],
    }),
    hdrs = [
        "sqlite3.h",
        "sqlite3ext.h",
    ],
    deps = ["@doltlite_amalgamation//:doltlite_headers"],
    includes = ["."],
    copts = [
        # `SQLITE_CORE` switches the bundled extensions (FTS3, FTS5,
        # RTree, …) from loadable-extension entry points to the
        # statically-callable init functions main.c expects (e.g.
        # `sqlite3Fts5Init`). The amalgamation defines it
        # automatically; the non-amalgamation build has to opt in.
        "-DSQLITE_CORE",
        # The flag that flips on the storage-engine swap + the
        # version-control SQL function registrations. Without it the
        # build is indistinguishable from upstream SQLite.
        "-DDOLTLITE_PROLLY=1",
        "-DDOLTLITE_VERSION=\\\"0.11.3\\\"",
        # SQLite vtable extensions doltlite expects (mirrors
        # OPT_FEATURE_FLAGS once DOLTLITE_PROLLY=1 is set upstream).
        "-DSQLITE_ENABLE_BYTECODE_VTAB",
        "-DSQLITE_ENABLE_DBPAGE_VTAB",
        "-DSQLITE_ENABLE_DBSTAT_VTAB",
        "-DSQLITE_ENABLE_FTS3",
        "-DSQLITE_ENABLE_FTS4",
        "-DSQLITE_ENABLE_FTS5",
        "-DSQLITE_ENABLE_RTREE",
        "-DSQLITE_ENABLE_STMTVTAB",
        "-DSQLITE_ENABLE_JSON1",
        "-DSQLITE_ENABLE_UNLOCK_NOTIFY",
        # ICU (Unicode tokenization for FTS3). doltlite enables this
        # by default; we have to either compile against the system
        # ICU libs or `-DSQLITE_OMIT_ICU` to skip — but we DO compile
        # ext/icu/icu.c, so the symbols are present.
        # sqlx-sqlite calls sqlite3_column_{database,origin,table}_name
        # for nullability inference. They're only defined when SQLite
        # is built with this flag; without it, link fails with
        # "Undefined symbols for architecture arm64:
        # _sqlite3_column_origin_name".
        "-DSQLITE_ENABLE_COLUMN_METADATA",
        "-DSQLITE_THREADSAFE=1",
        "-DSQLITE_DEFAULT_FOREIGN_KEYS=1",
        # Silence the noisier doltlite/SQLite build warnings — they
        # live in upstream-shaped code we don't own.
        "-Wno-unused-but-set-variable",
        "-Wno-unused-function",
        "-Wno-unused-parameter",
        "-Wno-unused-variable",
        "-Wno-unused-but-set-parameter",
        "-Wno-implicit-fallthrough",
        "-Wno-sign-compare",
        "-Wno-deprecated-non-prototype",
    ],
    linkopts = select({
        # POSIX threads for SQLITE_THREADSAFE=1; dl is needed if anyone
        # ever calls sqlite3_load_extension at runtime (we don't, but
        # the symbol references dlopen so the linker complains
        # otherwise on Linux).
        "@platforms//os:linux": [
            "-lpthread",
            "-ldl",
            "-lm",
        ],
        "@platforms//os:macos": [],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
