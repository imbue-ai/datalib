#!/bin/bash
# Pre-commit hook for mixed_up_files
# Runs linting and type checking before commits.
#
# To install: ./scripts/setup-hooks.sh

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Running pre-commit checks..."

# Snapshot the set of files the user explicitly staged for this commit
# *before* running any formatter. We use this list (not `git diff` after
# the fact) to decide what to re-stage post-format. Capturing it now
# prevents the hook from folding unrelated working-tree dirt into the
# commit just because a formatter happened to touch (or `git diff`
# happened to list) it. --diff-filter=ACMR ignores deletions and
# typechanges so we don't try to `git add` a path that no longer exists.
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
restage_if_staged() {
    if [ -n "$STAGED_FILES" ]; then
        # NUL-safe would be nicer but the filenames in this repo don't
        # contain newlines; keep it readable.
        echo "$STAGED_FILES" | xargs -r git add --
    fi
}

# --- Python (ruff + pyright via uv) ---
echo "[python] ruff check"
uv run ruff check .

echo "[python] ruff format"
uv run ruff format .
# ruff format mutates files in place. Re-stage only the files that were
# already part of this commit; never fold in unstaged dirt.
restage_if_staged

echo "[python] pyright"
uv run pyright

# --- TypeScript (frankweiler/ui) ---
if [ -d frankweiler/ui ]; then
    echo "[ui] vue-tsc"
    # pnpm pinned via frankweiler/ui/package.json's `packageManager`;
    # provisioned on demand via corepack. See scripts/ensure_pnpm.sh.
    # shellcheck source=ensure_pnpm.sh
    source "$REPO_ROOT/scripts/ensure_pnpm.sh"
    (
        cd frankweiler/ui
        if [ ! -d node_modules ]; then
            echo "  installing pnpm deps..."
            pnpm install --frozen-lockfile
        fi
        npx vue-tsc --noEmit
    )
fi

# --- Rust (frankweiler/backend) ---
if [ -d frankweiler/backend ]; then
    echo "[rust] cargo fmt --check"
    (cd frankweiler/backend && cargo fmt --all -- --check)

    echo "[rust] cargo clippy"
    # `disallowed_macros` is in the `restriction` group (not enabled by
    # default); flip it on here so the `eprintln!` / `println!` ban in
    # `frankweiler/backend/clippy.toml` becomes a hard error via `-D
    # warnings`. See that file's header for the rationale.
    (cd frankweiler/backend && cargo clippy --all-targets --all-features -- -W clippy::disallowed_macros -D warnings)
fi

echo "All pre-commit checks passed."
