#!/bin/bash
# Pre-commit hook for datalib
# Runs fast, auto-fixing lint/format on staged files before commits.
#
# The expensive gates (pyright, vue-tsc, cargo fmt, bazel clippy, rust
# unit-test coverage) used to live here too, but paying that cost on
# every commit was wasteful — they now run in scripts/pre-push instead.
# This hook keeps only the cheap ruff pass, whose auto-format + re-stage
# only makes sense at commit time anyway.
#
# To install: ./scripts/setup-hooks.sh

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Running pre-commit checks..."

# Snapshot the set of files the user explicitly staged for this commit
# *before* running any formatter. We use this list (not `git diff` after
# the fact) to decide what to re-stage post-format. Capturing it now
# prevents the hook from folding unrelated working-tree dirt into the
# commit just because a formatter happened to touch (or `git diff`
# happened to list) it. --diff-filter=ACMR ignores deletions and
# typechanges so we don't try to `git add` a path that no longer exists.
# Capture the staged-file list NUL-delimited so filenames with spaces
# (e.g. snapshot blobs named after attachments like "Hello World.pdf")
# survive the xargs round-trip. A shell variable can't hold NUL bytes
# — `$(...)` substitution strips them — so we route the list through a
# tempfile.
STAGED_FILES_LIST="$(mktemp -t pre-commit-staged-XXXXXX)"
trap 'rm -f "$STAGED_FILES_LIST"' EXIT
git diff -z --cached --name-only --diff-filter=ACMR > "$STAGED_FILES_LIST"
restage_if_staged() {
    if [ -s "$STAGED_FILES_LIST" ]; then
        xargs -0 -r git add -- < "$STAGED_FILES_LIST"
    fi
}

# --- Python (ruff + pyright via uv) ---
echo "[python] ruff check"
uv run ruff check .

echo "[python] ruff format"
uv run ruff format .
# ruff format mutates files in place. Re-stage only the files that were
# already part of this commit; never fold in unstaged dirt.
restage_if_staged

echo "All pre-commit checks passed."
