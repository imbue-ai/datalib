#!/bin/bash
# Pre-commit hook for mixed_up_files
# Runs linting and type checking before commits.
#
# To install: ./scripts/setup-hooks.sh

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Running pre-commit checks..."

# Snapshot the set of files the user explicitly staged for this commit
# *before* running any formatter. We use this list (not `git diff` after
# the fact) to decide what to re-stage post-format. Capturing it now
# prevents the hook from folding unrelated working-tree dirt into the
# commit just because a formatter happened to touch (or `git diff`
# happened to list) it. --diff-filter=ACMR ignores deletions and
# typechanges so we don't try to `git add` a path that no longer exists.
# Capture the staged-file list NUL-delimited so filenames with spaces
# (e.g. snapshot blobs named after attachments like "Hello World.pdf")
# survive the xargs round-trip. A shell variable can't hold NUL bytes
# — `$(...)` substitution strips them — so we route the list through a
# tempfile.
STAGED_FILES_LIST="$(mktemp -t pre-commit-staged-XXXXXX)"
trap 'rm -f "$STAGED_FILES_LIST"' EXIT
git diff -z --cached --name-only --diff-filter=ACMR > "$STAGED_FILES_LIST"
restage_if_staged() {
    if [ -s "$STAGED_FILES_LIST" ]; then
        xargs -0 -r git add -- < "$STAGED_FILES_LIST"
    fi
}

# --- Python (ruff + pyright via uv) ---
echo "[python] ruff check"
uv run ruff check .

echo "[python] ruff format"
uv run ruff format .
# ruff format mutates files in place. Re-stage only the files that were
# already part of this commit; never fold in unstaged dirt.
restage_if_staged

echo "[python] pyright"
uv run pyright

# --- TypeScript (frankweiler/ui) ---
if [ -d frankweiler/ui ]; then
    echo "[ui] vue-tsc"
    # pnpm pinned via frankweiler/ui/package.json's `packageManager`;
    # provisioned on demand via corepack. See scripts/ensure_pnpm.sh.
    # shellcheck source=ensure_pnpm.sh
    source "$REPO_ROOT/scripts/ensure_pnpm.sh"
    (
        cd frankweiler/ui
        if [ ! -d node_modules ]; then
            echo "  installing pnpm deps..."
            pnpm install --frozen-lockfile
        fi
        npx vue-tsc --noEmit
    )
fi

# --- Rust (frankweiler/backend) ---
if [ -d frankweiler/backend ]; then
    echo "[rust] cargo fmt --check"
    (cd frankweiler/backend && cargo fmt --all -- --check)

    echo "[rust] bazelisk build --config=clippy //..."
    # rules_rust clippy aspect. Replaces `cargo clippy --all-targets
    # --all-features -- -W clippy::disallowed_macros -D warnings`,
    # which was eating 60–120s per commit because its incremental
    # cache is separate from bazel's. Warm-cache runs of the aspect
    # are sub-second; see .bazelrc's `--config=clippy` block for the
    # rationale and the flag wiring (clippy.toml + -D warnings + the
    # `disallowed_macros` enable).
    bazelisk build --config=clippy //...

    # Guard: every rust_library must have a rust_test(crate=...) target,
    # else its inline #[cfg(test)] tests silently never run under
    # `bazel test //...`. Catches the gap that left fsindex's stamp.rs /
    # hash.rs tests dormant.
    echo "[rust] unit-test target coverage"
    "$REPO_ROOT/tools/check_rust_unit_tests.sh"
fi

echo "All pre-commit checks passed."
