# These are needed to forward on to bazel.
export DOLT_BIN=$(which dolt)
export NPX_BIN=$(which npx)
# Chrome-impersonating curl shim (Cloudflare bypass for claude.ai etc.).
# Built by `cargo build -p frankweiler-etl --bin latchkey-curl-shim` or
# `bazel build //frankweiler/backend/etl:latchkey_curl_shim`. Under bazel
# this is also resolved from runfiles; this export covers cargo runs and
# bazel actions that haven't declared the shim as a data dep.
if [ -x "$PWD/frankweiler/backend/target/debug/latchkey-curl-shim" ]; then
  export LATCHKEY_CURL="$PWD/frankweiler/backend/target/debug/latchkey-curl-shim"
fi
