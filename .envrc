# Pinned for direct-runtime resolution by the qmd_indexer crate when
# you're running the sync binary outside bazel (e.g. via `cargo run`).
# Bazel actions ignore this — they resolve `npx` against the PATH
# pinned in `.bazelrc` so action caching stays stable across hosts.
export NPX_BIN=$(which npx)


if [ -f .envrc.private ]; then
  source .envrc.private
fi
