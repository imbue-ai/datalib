{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "@schemas/*": ["../../schemas/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.vue", "tests/**/*"]
}
