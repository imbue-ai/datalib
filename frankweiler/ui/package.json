{
  "name": "frankweiler-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "ag-grid-community": "35.2.1",
    "ag-grid-enterprise": "35.2.1",
    "ag-grid-vue3": "35.2.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "7.3.3",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7"
  },
  "pnpm": {
    "//": "Declares which transitive deps may run postinstall lifecycle scripts under aspect_rules_js. Required by npm_translate_lock to parse the v9 lockfile. (Modern pnpm 10+ reads this from pnpm-workspace.yaml#allowBuilds instead and ignores this field — we keep it here for aspect_rules_js to find.)",
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
