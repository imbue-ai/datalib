load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")
load("//tools:insta.bzl", "insta_update")

exports_files([
    "BUILD.bazel",  # read by //frankweiler/backend:version_consistency_test
    "Cargo.toml",
])

rust_binary(
    name = "frankweiler_sync_bin",
    srcs = [
        "src/main.rs",
        "src/progress.rs",
        "src/summary.rs",
    ],
    edition = "2021",
    # Sets CARGO_PKG_VERSION under rules_rust (which does NOT read Cargo.toml).
    # The clap --version stamp now goes through FRANKWEILER_VERSION (git
    # describe), so this field is no longer user-facing — but other consumers
    # like http's /api/version still rely on CARGO_PKG_VERSION. Must match
    # [workspace.package].version in frankweiler/backend/Cargo.toml; the
    # //frankweiler/backend:version_consistency_test asserts that.
    version = "0.5.1",
    # Stamp the binary with STABLE_GIT_HASH from tools/workspace_status.sh
    # so `frankweiler-sync --version` reports the commit it was built from.
    # `stamp = -1` defers to the --stamp flag (forced on by .bazelrc), and
    # rustc_env.txt resolves {STABLE_GIT_HASH} into the FRANKWEILER_GIT_HASH
    # env consumed by `option_env!` in src/main.rs. Wired on the binary
    # only — not on frankweiler_core — to keep the per-commit invalidation
    # off the rest of the build graph.
    rustc_env_files = ["rustc_env.txt"],
    stamp = -1,
    visibility = ["//visibility:public"],
    deps = [
        "//frankweiler/backend/core:frankweiler_core",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/etl/providers/anthropic:frankweiler_etl_anthropic",
        "//frankweiler/backend/etl/providers/beeper:frankweiler_etl_beeper",
        "//frankweiler/backend/etl/providers/contacts:frankweiler_etl_contacts",
        "//frankweiler/backend/etl/providers/chatgpt:frankweiler_etl_chatgpt",
        "//frankweiler/backend/etl/providers/github:frankweiler_etl_github",
        "//frankweiler/backend/etl/providers/gitlab:frankweiler_etl_gitlab",
        "//frankweiler/backend/etl/providers/notion:frankweiler_etl_notion",
        "//frankweiler/backend/etl/providers/perseus:frankweiler_etl_perseus",
        "//frankweiler/backend/etl/providers/slack:frankweiler_etl_slack",
        "//frankweiler/backend/obs:frankweiler_obs",
        "//frankweiler/backend/qmd_indexer:frankweiler_qmd_indexer",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:chrono",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:indicatif",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

# Unit tests embedded in `src/main.rs` via `#[cfg(test)] mod ...`.
# Only `mod interrupt_tests` is non-trivial today — it exercises the
# SIGINT-handler commit path (`interrupt_commit_all`) directly against
# a constructed `CtrlcState`, since signal-delivery testing is harder
# than driving the function we'd call from the signal handler.
rust_test(
    name = "frankweiler_sync_bin_unittests",
    crate = ":frankweiler_sync_bin",
    edition = "2021",
    deps = [
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
    ],
)

# Live end-to-end golden test. Drives the sync binary against
# configs/thad_tiny.yaml into a fresh tempdir and snapshots the raw +
# rendered_md trees plus the sync_summary_<now>.json. Manual: hits the
# network, needs latchkey creds.
rust_test(
    name = "manual_e2e_live_sync_golden",
    srcs = ["tests/manual_e2e_live_sync_golden.rs"],
    crate_root = "tests/manual_e2e_live_sync_golden.rs",
    data = [
        ":frankweiler_sync_bin",
        "//configs:thad_tiny.yaml",
    ] + glob(
        ["tests/snapshots/**/*.snap"],
        allow_empty = True,
    ),
    edition = "2021",
    env = {
        "FRANKWEILER_SYNC_BIN": "$(rootpath :frankweiler_sync_bin)",
        "FRANKWEILER_TEST_CONFIG": "$(rootpath //configs:thad_tiny.yaml)",
        "INSTA_WORKSPACE_ROOT": ".",
    },
    tags = [
        "external",  # talks to real provider APIs
        "manual",
        "no-sandbox",  # latchkey reads keyring + LATCHKEY_CURL from host
    ],
    deps = [
        "@frankweiler_crates//:insta",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:serde_yaml",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:walkdir",
    ],
)

# `bazel run //frankweiler/backend/sync:manual_e2e_live_sync_golden.update`
# re-runs the live test with INSTA_UPDATE=always and writes the new
# snapshots into the source tree (not the sandbox). Set LATCHKEY_CURL
# on the host before invoking — same prereq as `cargo test`.
insta_update(
    name = "manual_e2e_live_sync_golden.update",
    test = ":manual_e2e_live_sync_golden",
    test_args = ["--ignored"],
    # Mirrors the rust_test's data + env so the .update sh_binary
    # resolves FRANKWEILER_SYNC_BIN / FRANKWEILER_TEST_CONFIG the same
    # way `bazel test` would. The base macro doesn't see those because
    # bazel doesn't propagate a rust_test's env to its sibling sh_binary.
    extra_data = [
        ":frankweiler_sync_bin",
        "//configs:thad_tiny.yaml",
    ],
    extra_env = {
        "FRANKWEILER_SYNC_BIN": "$(rootpath :frankweiler_sync_bin)",
        "FRANKWEILER_TEST_CONFIG": "$(rootpath //configs:thad_tiny.yaml)",
    },
)
