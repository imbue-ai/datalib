load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

exports_files(["Cargo.toml"])

rust_library(
    name = "frankweiler_whatsapp_backup",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "frankweiler_whatsapp_backup",
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        "@frankweiler_crates//:aes",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:cipher",
        "@frankweiler_crates//:ctr",
        "@frankweiler_crates//:flate2",
        "@frankweiler_crates//:ghash",
        "@frankweiler_crates//:hmac",
        "@frankweiler_crates//:md-5",
        "@frankweiler_crates//:sha2",
        "@frankweiler_crates//:subtle",
        "@frankweiler_crates//:thiserror",
    ],
)

rust_test(
    name = "whatsapp_backup_unittests",
    size = "small",
    crate = ":frankweiler_whatsapp_backup",
    edition = "2021",
    deps = [
        "@frankweiler_crates//:tempfile",
    ],
)
