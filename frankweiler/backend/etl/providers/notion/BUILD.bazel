load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")
load("//tools:insta.bzl", "insta_update")

exports_files(["Cargo.toml"])

rust_library(
    name = "frankweiler_etl_notion",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/bin/**"],
    ),
    crate_name = "frankweiler_etl_notion",
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/schema:frankweiler_schema",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:chrono",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:once_cell",
        "@frankweiler_crates//:regex",
        "@frankweiler_crates//:serde",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:thiserror",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
        "@frankweiler_crates//:uuid",
    ],
)

rust_binary(
    name = "notion_download",
    srcs = ["src/bin/notion_download.rs"],
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        ":frankweiler_etl_notion",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/obs:frankweiler_obs",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

rust_binary(
    name = "notion_translate",
    srcs = ["src/bin/notion_translate.rs"],
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        ":frankweiler_etl_notion",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/obs:frankweiler_obs",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

rust_test(
    name = "notion_unittests",
    size = "small",
    crate = ":frankweiler_etl_notion",
    edition = "2021",
)

rust_test(
    name = "notion_playback_roundtrip",
    srcs = ["tests/playback_roundtrip.rs"],
    crate_root = "tests/playback_roundtrip.rs",
    edition = "2021",
    deps = [
        ":frankweiler_etl_notion",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)

rust_test(
    name = "notion_blob_render",
    srcs = ["tests/blob_render.rs"],
    crate_root = "tests/blob_render.rs",
    edition = "2021",
    deps = [
        ":frankweiler_etl_notion",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
    ],
)

rust_test(
    name = "notion_live",
    srcs = ["tests/notion_live.rs"],
    crate_root = "tests/notion_live.rs",
    data = glob(["tests/snapshots/notion_live__*.snap"], allow_empty = True),
    edition = "2021",
    env = {
        "INSTA_WORKSPACE_ROOT": ".",
    },
    tags = [
        "external",  # talks to api.notion.com
        "manual",
        "no-sandbox",  # latchkey reads keyring + LATCHKEY_CURL from host
    ],
    deps = [
        ":frankweiler_etl_notion",
        "@frankweiler_crates//:insta",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)

insta_update(
    name = "notion_live.update",
    test = ":notion_live",
    test_args = ["--ignored"],
)
