load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")
load("//tools:insta.bzl", "insta_update")

exports_files(["Cargo.toml"])

# Filegroup for the checked-in TNG-themed fixture used by both Rust
# integration tests here and the Python fixture-build pipeline at
# //tests/fixtures:ingested_tng.
filegroup(
    name = "tng_fixture",
    srcs = glob(["tests/fixtures/chatgpt_api/**/*.json"]),
    visibility = ["//visibility:public"],
)

rust_library(
    name = "frankweiler_etl_chatgpt",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/bin/**"],
    ),
    crate_name = "frankweiler_etl_chatgpt",
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/schema:frankweiler_schema",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:chrono",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:once_cell",
        "@frankweiler_crates//:regex",
        "@frankweiler_crates//:serde",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:thiserror",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
        "@frankweiler_crates//:tracing-indicatif",
        "@frankweiler_crates//:uuid",
    ],
)

rust_binary(
    name = "chatgpt_download",
    srcs = ["src/bin/chatgpt_download.rs"],
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        ":frankweiler_etl_chatgpt",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/obs:frankweiler_obs",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

rust_binary(
    name = "chatgpt_translate",
    srcs = ["src/bin/chatgpt_translate.rs"],
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        ":frankweiler_etl_chatgpt",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/obs:frankweiler_obs",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

rust_test(
    name = "chatgpt_playback_roundtrip",
    srcs = ["tests/playback_roundtrip.rs"],
    crate_root = "tests/playback_roundtrip.rs",
    edition = "2021",
    deps = [
        ":frankweiler_etl_chatgpt",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)

rust_test(
    name = "chatgpt_unittests",
    size = "small",
    crate = ":frankweiler_etl_chatgpt",
    edition = "2021",
)

# Translate smoke test against the in-crate TNG fixture. The fixture
# lives in-crate; bazel stages it via `data` and points
# CHATGPT_FIXTURE_DIR at the runfiles-relative path (the test source
# reads that env var with CARGO_MANIFEST_DIR as the cargo fallback).
rust_test(
    name = "chatgpt_translate_test",
    srcs = ["tests/chatgpt_translate.rs"],
    crate_root = "tests/chatgpt_translate.rs",
    data = [":tng_fixture"],
    edition = "2021",
    env = {
        "CHATGPT_FIXTURE_DIR": "frankweiler/backend/etl/providers/chatgpt/tests/fixtures/chatgpt_api",
    },
    deps = [
        ":frankweiler_etl_chatgpt",
    ],
)

# Render golden test. Fixture lives in-crate; resolved via
# CARGO_MANIFEST_DIR which bazel doesn't surface in sandbox runfiles,
# so tag manual. Run via `cargo test -p frankweiler-etl-chatgpt`.
rust_test(
    name = "chatgpt_live",
    srcs = ["tests/chatgpt_live.rs"],
    crate_root = "tests/chatgpt_live.rs",
    data = glob(["tests/snapshots/chatgpt_live__*.snap"], allow_empty = True),
    edition = "2021",
    env = {
        "INSTA_WORKSPACE_ROOT": ".",
    },
    tags = [
        "external",  # talks to chatgpt.com
        "manual",
        "no-sandbox",  # latchkey reads keyring + LATCHKEY_CURL from host
    ],
    deps = [
        ":frankweiler_etl_chatgpt",
        "@frankweiler_crates//:insta",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)

rust_test(
    name = "chatgpt_render",
    srcs = ["tests/chatgpt_render.rs"],
    crate_root = "tests/chatgpt_render.rs",
    data = glob(["tests/snapshots/*.snap"], allow_empty = True) + [":tng_fixture"],
    edition = "2021",
    env = {
        "CHATGPT_FIXTURE_DIR": "frankweiler/backend/etl/providers/chatgpt/tests/fixtures/chatgpt_api",
        "INSTA_WORKSPACE_ROOT": ".",
    },
    deps = [
        ":frankweiler_etl_chatgpt",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:insta",
        "@frankweiler_crates//:tempfile",
    ],
)

# `bazel run //...:foo.update` siblings that re-run the insta-using
# test with INSTA_UPDATE=always and write back into the source tree.
insta_update(
    name = "chatgpt_render.update",
    test = ":chatgpt_render",
)

insta_update(
    name = "chatgpt_live.update",
    test = ":chatgpt_live",
    test_args = ["--ignored"],
)
