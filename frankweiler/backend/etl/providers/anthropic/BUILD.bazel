load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")
load("//tools:insta.bzl", "insta_update")

exports_files(["Cargo.toml"])

# Filegroup for the checked-in TNG-themed fixture used by both Rust
# integration tests here and the Python fixture-build pipeline at
# //tests/fixtures:ingested_tng.
filegroup(
    name = "tng_fixture",
    srcs = glob(["tests/fixtures/anthropic_api/**/*.json"]),
    visibility = ["//visibility:public"],
)

rust_library(
    name = "frankweiler_etl_anthropic",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/bin/**"],
    ),
    crate_name = "frankweiler_etl_anthropic",
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/schema:frankweiler_schema",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:chrono",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:once_cell",
        "@frankweiler_crates//:regex",
        "@frankweiler_crates//:serde",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:thiserror",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
        "@frankweiler_crates//:uuid",
    ],
)

rust_binary(
    name = "anthropic_download",
    srcs = ["src/bin/anthropic_download.rs"],
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        ":frankweiler_etl_anthropic",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/obs:frankweiler_obs",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

rust_test(
    name = "anthropic_playback_roundtrip",
    srcs = ["tests/playback_roundtrip.rs"],
    crate_root = "tests/playback_roundtrip.rs",
    edition = "2021",
    deps = [
        ":frankweiler_etl_anthropic",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)

rust_test(
    name = "anthropic_unittests",
    size = "small",
    crate = ":frankweiler_etl_anthropic",
    edition = "2021",
)

# Translate smoke test against the in-crate TNG fixture. Bazel stages
# the fixture via `data` and points `ANTHROPIC_FIXTURE_DIR` at the
# runfiles-relative path (the test reads it with CARGO_MANIFEST_DIR
# as the cargo fallback).
rust_test(
    name = "anthropic_translate_test",
    srcs = ["tests/anthropic_translate.rs"],
    crate_root = "tests/anthropic_translate.rs",
    data = [":tng_fixture"],
    edition = "2021",
    env = {
        "ANTHROPIC_FIXTURE_DIR": "frankweiler/backend/etl/providers/anthropic/tests/fixtures/anthropic_api",
    },
    deps = [
        ":frankweiler_etl_anthropic",
    ],
)

rust_test(
    name = "anthropic_live",
    srcs = ["tests/anthropic_live.rs"],
    crate_root = "tests/anthropic_live.rs",
    data = glob(["tests/snapshots/anthropic_live__*.snap"], allow_empty = True),
    edition = "2021",
    env = {
        "INSTA_WORKSPACE_ROOT": ".",
    },
    tags = [
        "external",  # talks to claude.ai/api
        "manual",
        "no-sandbox",  # latchkey reads keyring + LATCHKEY_CURL from host
    ],
    deps = [
        ":frankweiler_etl_anthropic",
        "@frankweiler_crates//:insta",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)

rust_test(
    name = "anthropic_render",
    srcs = ["tests/anthropic_render.rs"],
    crate_root = "tests/anthropic_render.rs",
    data = glob(["tests/snapshots/*.snap"], allow_empty = True) + [":tng_fixture"],
    edition = "2021",
    env = {
        "ANTHROPIC_FIXTURE_DIR": "frankweiler/backend/etl/providers/anthropic/tests/fixtures/anthropic_api",
        "INSTA_WORKSPACE_ROOT": ".",
    },
    deps = [
        ":frankweiler_etl_anthropic",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:insta",
        "@frankweiler_crates//:tempfile",
    ],
)

insta_update(
    name = "anthropic_render.update",
    test = ":anthropic_render",
)

insta_update(
    name = "anthropic_live.update",
    test = ":anthropic_live",
    test_args = ["--ignored"],
)
