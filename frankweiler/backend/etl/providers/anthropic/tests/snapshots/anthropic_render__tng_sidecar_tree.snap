    },
    {
      "uuid": "50000001-1701-4d00-8000-000000050001",
      "provider": "anthropic",
      "kind": "User Input",
      "source_label": "Claude",
      "when_ts": "2369-04-16T09:00:00.000000+00:00",
      "author": "00000001-1701-4d00-8000-000000000001",
      "account": "00000001-1701-4d00-8000-000000000001",
      "project": null,
      "channel": null,
      "conversation_name": "Borg Encryption Signature Lookup",
      "conversation_uuid": "c0000005-1701-4d00-8000-00000000c005",
      "message_index": 0,
      "entire_chat": "/chat/c0000005-1701-4d00-8000-00000000c005",
      "text": "Look up the Borg adaptive-shield signature 7-of-9-alpha and tell me if we have a counter on file.",
      "slack_link": null,
      "qmd_path": "rendered_md/anthropic/00000001-1701-4d00-8000-000000000001/llm_chats/c0000005-1701-4d00-8000-00000000c005/index.md",
