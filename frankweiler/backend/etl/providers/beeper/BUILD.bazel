load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

exports_files(["Cargo.toml"])

# Checked-in ST:TNG-themed fixture, consumed by:
#   * the per-crate `beeper_tng_e2e` integration test (data = below)
#   * the unified //tests/fixtures:ingested_tng genrule that builds
#     `backend_index.doltlite_db` against every provider's fixtures.
#
# The fixture is SQL + a couple of small media files; the consumer
# `materialize`s a Beeper-Texts-shaped dir from those before running
# `beeper-download`.
filegroup(
    name = "tng_fixture",
    srcs = glob([
        "tests/fixtures/beeper_tng/*.sql",
        "tests/fixtures/beeper_tng/media/**/*",
    ]) + [
        "tests/fixtures/beeper_tng/build_fixture.sh",
    ],
    visibility = ["//visibility:public"],
)

rust_library(
    name = "frankweiler_etl_beeper",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/bin/**"],
    ),
    crate_name = "frankweiler_etl_beeper",
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/schema:frankweiler_schema",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:chrono",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:serde",
        "@frankweiler_crates//:serde_json",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:thiserror",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
        "@frankweiler_crates//:uuid",
    ],
)

# Extract step (Beeper). CLI driver. Reads BeeperTexts' on-disk
# SQLite stores (index.db, media/) directly — no network, no auth.
rust_binary(
    name = "beeper_download",
    srcs = ["src/bin/beeper_download.rs"],
    edition = "2021",
    visibility = ["//frankweiler:__subpackages__"],
    deps = [
        ":frankweiler_etl_beeper",
        "//frankweiler/backend/etl:frankweiler_etl",
        "//frankweiler/backend/obs:frankweiler_obs",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:clap",
        "@frankweiler_crates//:tokio",
        "@frankweiler_crates//:tracing",
    ],
)

rust_test(
    name = "beeper_unittests",
    size = "small",
    crate = ":frankweiler_etl_beeper",
    edition = "2021",
)

# End-to-end test against the checked-in TNG fixture: materializes a
# BeeperTexts-shaped dir from `:tng_fixture` into a tempdir, runs the
# extract + translate pipeline, asserts the resulting doltlite and
# rendered markdown.
#
# `BEEPER_SQLITE3` can be set to an absolute sqlite3 path if the
# sandbox doesn't put one on PATH; macOS sandboxes include
# /usr/bin/sqlite3 by default.
rust_test(
    name = "beeper_tng_e2e",
    srcs = ["tests/beeper_tng_e2e.rs"],
    crate_root = "tests/beeper_tng_e2e.rs",
    data = [":tng_fixture"],
    edition = "2021",
    # Bazel doesn't surface fixture dirs via CARGO_MANIFEST_DIR in the
    # sandbox — the test reads BEEPER_FIXTURE_DIR with CARGO_MANIFEST_DIR
    # as the cargo fallback. Mirrors the chatgpt / anthropic /
    # notion translate-test wiring.
    env = {
        "BEEPER_FIXTURE_DIR": "frankweiler/backend/etl/providers/beeper/tests/fixtures/beeper_tng",
    },
    deps = [
        ":frankweiler_etl_beeper",
        "//frankweiler/backend/etl:frankweiler_etl",
        "@frankweiler_crates//:anyhow",
        "@frankweiler_crates//:sqlx",
        "@frankweiler_crates//:tempfile",
        "@frankweiler_crates//:tokio",
    ],
)
