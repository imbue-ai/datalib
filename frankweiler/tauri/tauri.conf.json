{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Frankweiler",
  "version": "0.10.0",
  "identifier": "com.imbue.frankweiler",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --dir ui dev",
    "beforeBuildCommand": "bazelisk build //third-party/doltlite:sqlite3 && pnpm --dir ui install --frozen-lockfile && pnpm --dir ui build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
